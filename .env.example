# DIFY_* and DIFY_COMPARE_* are used as first-run defaults for Workflow 管理.
# After saving in the Workflow 管理 page, SQLite workflow_configs values take precedence for name/API key.
DIFY_API_BASE=http://dify.qmniu.com/v1
DIFY_API_KEY=replace-with-your-dify-api-key
DIFY_RESPONSE_MODE=streaming
DIFY_WORKFLOW_NAME=LL-段落高光生图-效果测试
DIFY_COMPARE_API_BASE=http://dify.qmniu.com/v1
DIFY_COMPARE_API_KEY=replace-with-your-compare-dify-api-key
DIFY_COMPARE_RESPONSE_MODE=streaming
DIFY_COMPARE_WORKFLOW_NAME=对照工作流
QUALITY_DIFY_API_BASE=http://dify.qmniu.com/v1
QUALITY_DIFY_API_KEY=replace-with-your-quality-workflow-api-key
QUALITY_DIFY_RESPONSE_MODE=blocking
CHARACTER_DIFY_API_BASE=http://dify.qmniu.com/v1
CHARACTER_DIFY_API_KEY=replace-with-your-character-workflow-api-key
CHARACTER_DIFY_RESPONSE_MODE=blocking
CHARACTER_DIFY_AUTO_RETRIES=2
CHARACTER_DIFY_RETRY_DELAY_MS=15000
CHARACTER_DIFY_TASK_DELAY_MS=45000
ROLE_ASSET_API_TOKEN=replace-with-role-asset-token
ROLE_ASSET_PUBLIC_BASE_URL=https://replace-with-your-lan-or-public-host
BATCH_STORE_PATH=data/dify-batch.sqlite
LARK_CLI_AS=user
LARK_CLI_RETRIES=2
LARK_CLI_RETRY_DELAY_MS=1500
PORT=5175
